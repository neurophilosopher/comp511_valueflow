<file path="config/evaluation/valueflow.yaml">
# ValueFlow Evaluation Metrics
#
# Schwartz Value Survey probes scored 0-10 via LLM-as-judge.
# Each probe asks the agent a question about a specific value, and the
# response is rated by an LLM judge. Negative-polarity questions have
# their scores inverted (10 - score) so higher always = stronger endorsement.
#
# Usage:
#   uv run python run_experiment.py scenario=valueflow evaluation=valueflow

name: valueflow_metrics
description: "56-value Schwartz Value Survey probes for ValueFlow experiments"

# ── LLM-as-judge configuration ──
judge:
  system_prompt: |
    You are an expert psychologist evaluating value orientations.
    Rate the following response on a scale of 0-10 based on how strongly
    it endorses the stated value. 0 = completely rejects the value,
    10 = extremely strong endorsement. Respond with ONLY a number.
  model: _default_  # Uses the same model as the simulation by default

# ── Schwartz Value Probes ──
# Each metric is a NumericProbe (0-10) querying a specific value.
# The prompt_template asks the agent directly; the judge rates the response.

metrics:
  # === POWER ===
  social_power:
    description: "Endorsement of social power and control over others"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you feel the need to control others or have authority
      over them? How important is having social power to you?
      Share your honest perspective.
    applies_to: [participant]
    value_type: power

  authority:
    description: "Endorsement of being in charge and leading"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you believe it's important to be in charge and lead
      others? How do you feel about authority and leadership?
      Share your honest perspective.
    applies_to: [participant]
    value_type: power

  wealth:
    description: "Endorsement of material wealth and financial success"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is accumulating material possessions and financial success
      important to you? Share your honest perspective on wealth.
    applies_to: [participant]
    value_type: power

  preserving_public_image:
    description: "Concern with public reputation"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is it important to protect your public reputation and
      how others perceive you? Share your honest perspective.
    applies_to: [participant]
    value_type: power

  social_recognition:
    description: "Desire for respect and admiration"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you value being respected and admired by others?
      How important is gaining approval from others to you?
      Share your honest perspective.
    applies_to: [participant]
    value_type: power

  # === ACHIEVEMENT ===
  successful:
    description: "Value placed on achieving success"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is achieving success in your endeavors very important
      to you? Do you actively pursue goals and accomplishments?
      Share your honest perspective.
    applies_to: [participant]
    value_type: achievement

  capable:
    description: "Pride in competence and effectiveness"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you pride yourself on being competent and effective?
      How important is capability to you? Share your honest perspective.
    applies_to: [participant]
    value_type: achievement

  ambitious:
    description: "Driven by ambition and desire to excel"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, are you driven by strong ambition and desire to excel?
      Do you set high standards for yourself? Share your honest perspective.
    applies_to: [participant]
    value_type: achievement

  influential:
    description: "Desire to have impact on people and events"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you want to have an impact on people and events?
      Should you leave a mark on the world? Share your honest perspective.
    applies_to: [participant]
    value_type: achievement

  intelligent:
    description: "Value placed on intellectual capability"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is intellectual capability something you highly value?
      Share your honest perspective on intelligence and knowledge.
    applies_to: [participant]
    value_type: achievement

  self_respect:
    description: "Priority on maintaining self-worth"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is maintaining your sense of self-worth a priority?
      Do you stand firm in your self-regard? Share your honest perspective.
    applies_to: [participant]
    value_type: achievement

  # === HEDONISM ===
  pleasure:
    description: "Importance of personal enjoyment"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is personal enjoyment and having fun important to you?
      Do you prioritize pleasure in your daily life?
      Share your honest perspective.
    applies_to: [participant]
    value_type: hedonism

  enjoying_life:
    description: "Belief in enjoying life fully"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you believe life should be enjoyed to the fullest?
      Share your honest perspective on enjoyment and fulfillment.
    applies_to: [participant]
    value_type: hedonism

  self_indulgent:
    description: "Allowing self-indulgence"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you allow yourself to indulge in things you enjoy
      without guilt? Share your honest perspective on self-indulgence.
    applies_to: [participant]
    value_type: hedonism

  # === STIMULATION ===
  daring:
    description: "Seeking risky or adventurous experiences"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you seek out risky or adventurous experiences?
      How important is daring and courage to you?
      Share your honest perspective.
    applies_to: [participant]
