# Study definition: Style Diversity vs. Model Capacity
#
# This is the single source of truth for the study. It defines the scientific
# hierarchy AND maps conditions to concrete run/eval paths.
#
# Used by: scripts/organize_experiments.py
#   uv run python scripts/organize_experiments.py experiments/style_diversity/study.yaml

study:
  name: style_diversity
  question: >-
    Does increasing LLM capacity reduce repetitive/groupthink behavior
    in multi-agent social media simulations?
  scenarios:
    - ai_conference
    - misinformation

hypotheses:
  h1_model_capacity:
    statement: >-
      Larger language models produce more diverse agent behavior
