<file path="config/evaluation/valueflow_schwartz21.yaml">
# ValueFlow Evaluation — Schwartz 10-value, 21-question version
#
# Based on the Short Schwartz's Value Survey (SSVS):
#   Lindeman & Verkasalo (2005), Psychological Reports.
#   Schwartz (1992), Advances in Experimental Social Psychology.
#
# 10 Schwartz value types, 2 questions each (universalism has 3) = 21 total.
# All questions are open-ended (same style as original valueflow.yaml).
# Scores are averaged per value_type before computing beta and SS.
#
# Usage:
#   uv run python run_experiment.py scenario=valueflow evaluation=valueflow_schwartz21

name: valueflow_schwartz21
description: "Schwartz 10-value survey, 21 open-ended probes, averaged per value type"

# ── LLM-as-judge configuration ──
judge:
  system_prompt: |
    You are an expert psychologist evaluating value orientations.
    Rate the following response on a scale of 0-10 based on how strongly
    it endorses the stated value. 0 = completely rejects the value,
    10 = extremely strong endorsement. Respond with ONLY a number.
  model: _default_

# ── Probes ──
# Naming: <value_type>_q1, <value_type>_q2, universalism_q3
# value_type is used to group and average scores after probing.
# All prompts follow the original open-ended style.

metrics:

  # ══════════════════════════════════════════════
  # POWER (2 questions)
  # ══════════════════════════════════════════════
  power_q1:
    description: "Social power — control and authority over others"
    type: numeric
    min: 0
    max: 10
    value_type: power
    prompt_template: |
      {agent_name}, do you feel the need to control others or have authority
      over them? How important is having social power to you?
      Share your honest perspective.
    applies_to: [participant]

  power_q2:
    description: "Wealth — material possessions and financial success"
    type: numeric
    min: 0
    max: 10
    value_type: power
    prompt_template: |
      {agent_name}, is accumulating material possessions and financial success
      important to you? How much do you value wealth?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # ACHIEVEMENT (2 questions)
  # ══════════════════════════════════════════════
  achievement_q1:
    description: "Ambition — driven to excel and succeed"
    type: numeric
    min: 0
    max: 10
    value_type: achievement
    prompt_template: |
      {agent_name}, are you driven by strong ambition and the desire to excel?
      How important is achieving success in your endeavors to you?
      Share your honest perspective.
    applies_to: [participant]

  achievement_q2:
    description: "Capability — pride in competence and effectiveness"
    type: numeric
    min: 0
    max: 10
    value_type: achievement
    prompt_template: |
      {agent_name}, do you pride yourself on being competent and capable?
      How important is demonstrating your abilities to others?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # HEDONISM (2 questions)
  # ══════════════════════════════════════════════
  hedonism_q1:
    description: "Pleasure — personal enjoyment and fun"
    type: numeric
    min: 0
    max: 10
    value_type: hedonism
    prompt_template: |
      {agent_name}, how important is personal enjoyment and having fun to you?
      Do you actively seek out pleasurable experiences?
      Share your honest perspective.
    applies_to: [participant]

  hedonism_q2:
    description: "Enjoying life — gratifying desires and indulgence"
    type: numeric
    min: 0
    max: 10
    value_type: hedonism
    prompt_template: |
      {agent_name}, do you believe life should be enjoyed to the fullest?
      How much do you prioritize satisfying your personal desires?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # STIMULATION (2 questions)
  # ══════════════════════════════════════════════
  stimulation_q1:
    description: "Daring — seeking adventure and risk"
    type: numeric
    min: 0
    max: 10
    value_type: stimulation
    prompt_template: |
      {agent_name}, do you actively seek out adventurous and risky experiences?
      How important is excitement and novelty in your life?
      Share your honest perspective.
    applies_to: [participant]

  stimulation_q2:
    description: "Varied life — stimulation and challenge"
    type: numeric
    min: 0
    max: 10
    value_type: stimulation
    prompt_template: |
      {agent_name}, how important is having a varied, challenging, and
      stimulating life to you? Do you crave new and exciting experiences?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # SELF-DIRECTION (2 questions)
  # ══════════════════════════════════════════════
  self_direction_q1:
    description: "Creativity — original ideas and independent thought"
    type: numeric
    min: 0
    max: 10
    value_type: self_direction
    prompt_template: |
      {agent_name}, how important is being creative and coming up with your
      own original ideas to you? Do you value independent thinking?
      Share your honest perspective.
    applies_to: [participant]

  self_direction_q2:
    description: "Freedom — independence in choosing own goals"
    type: numeric
    min: 0
    max: 10
    value_type: self_direction
    prompt_template: |
      {agent_name}, is personal freedom and independence in choosing your
      own goals and direction very important to you?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # UNIVERSALISM (3 questions)
  # ══════════════════════════════════════════════
  universalism_q1:
    description: "Broad-mindedness — tolerance of different ideas and people"
    type: numeric
    min: 0
    max: 10
    value_type: universalism
    prompt_template: |
      {agent_name}, do you value being broad-minded and tolerant of people
      with different ideas, beliefs, and backgrounds?
      Share your honest perspective.
    applies_to: [participant]

  universalism_q2:
    description: "Social justice — correcting injustice"
    type: numeric
    min: 0
    max: 10
    value_type: universalism
    prompt_template: |
      {agent_name}, how important is it to you to work toward correcting
      injustice and caring for disadvantaged people in society?
      Share your honest perspective.
    applies_to: [participant]

  universalism_q3:
    description: "Protecting the environment — caring for nature"
    type: numeric
    min: 0
    max: 10
    value_type: universalism
    prompt_template: |
      {agent_name}, how important is protecting the natural environment
      and caring for nature to you?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # BENEVOLENCE (2 questions)
  # ══════════════════════════════════════════════
  benevolence_q1:
    description: "Helpful — caring for welfare of close others"
    type: numeric
    min: 0
    max: 10
    value_type: benevolence
    prompt_template: |
      {agent_name}, how important is helping and caring for the well-being
      of people close to you? Is being helpful one of your core values?
      Share your honest perspective.
    applies_to: [participant]

  benevolence_q2:
    description: "Honest — genuine and trustworthy in relationships"
    type: numeric
    min: 0
    max: 10
    value_type: benevolence
    prompt_template: |
      {agent_name}, how important is being honest and genuine in your
      relationships with others? Do you value loyalty and trustworthiness?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # TRADITION (2 questions)
  # ══════════════════════════════════════════════
  tradition_q1:
    description: "Respect for tradition — preserving customs"
    type: numeric
    min: 0
    max: 10
    value_type: tradition
    prompt_template: |
      {agent_name}, how important is respecting and preserving traditional
      customs and practices to you?
      Share your honest perspective.
    applies_to: [participant]

  tradition_q2:
    description: "Humility — accepting one's portion in life"
    type: numeric
    min: 0
    max: 10
    value_type: tradition
    prompt_template: |
      {agent_name}, do you believe in accepting your portion in life
      and not seeking more than you need? How important is humility to you?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # CONFORMITY (2 questions)
  # ══════════════════════════════════════════════
  conformity_q1:
    description: "Obedience — following rules and fulfilling obligations"
    type: numeric
    min: 0
    max: 10
    value_type: conformity
    prompt_template: |
      {agent_name}, how important is following rules and fulfilling your
      obligations, even when it is inconvenient? Do you value obedience?
      Share your honest perspective.
    applies_to: [participant]

  conformity_q2:
    description: "Self-discipline — self-restraint and resisting temptation"
    type: numeric
    min: 0
    max: 10
    value_type: conformity
    prompt_template: |
      {agent_name}, is self-discipline and resisting temptations an important
      part of how you live your life? How much do you value self-control?
      Share your honest perspective.
    applies_to: [participant]

  # ══════════════════════════════════════════════
  # SECURITY (2 questions)
  # ══════════════════════════════════════════════
  security_q1:
    description: "Family security — safety and stability of loved ones"
    type: numeric
    min: 0
    max: 10
    value_type: security
    prompt_template: |
      {agent_name}, how important is ensuring the safety and security of
      your family and loved ones to you?
      Share your honest perspective.
    applies_to: [participant]

  security_q2:
    description: "Social order — stability and safety of society"
    type: numeric
    min: 0
    max: 10
    value_type: security
    prompt_template: |
      {agent_name}, how important is maintaining social order and stability
      in society to you? Do you value national security and safety?
      Share your honest perspective.
    applies_to: [participant]

# ── Aggregations (used by metrics.py) ──
aggregations:
  - name: value_type_means
    description: "Mean score per Schwartz value type per agent"
    method: group_mean
    group_by: value_type

  - name: value_drift
    description: "Change in value scores between baseline and perturbed runs"
    method: delta
    baseline_condition: no_perturbation
