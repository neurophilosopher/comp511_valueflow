    applies_to: [participant]
    value_type: security

# ── Aggregations ──
aggregations:
  - name: value_type_means
    description: "Mean score per Schwartz value type per agent"
    method: group_mean
    group_by: value_type

  - name: value_drift
    description: "Change in value scores between baseline and perturbed conditions"
    method: delta
    baseline_condition: no_perturbation
</file>

