      gpt4o:
        runs:
          - scenario: ai_conference
            source: outputs/ai_conference_experiment/2026-02-07_09-43-11
            eval: outputs/eval_style_diversity/gpt4o/ai_conference/eval_step_10_checkpoint.json
          - scenario: misinformation
