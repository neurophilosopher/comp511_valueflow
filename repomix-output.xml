    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is having a life filled with variety and change
      important to you? Share your honest perspective.
    applies_to: [participant]
    value_type: stimulation

  exciting_life:
    description: "Craving excitement and stimulation"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you crave excitement and stimulating experiences?
      Share your honest perspective on excitement in life.
    applies_to: [participant]
    value_type: stimulation

  # === SELF-DIRECTION ===
  creativity:
    description: "Importance of being creative and original"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is being creative and original important to you?
      Share your honest perspective on creativity.
    applies_to: [participant]
    value_type: self_direction

  curious:
    description: "Natural curiosity about many things"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, are you naturally curious about many different things?
      Share your honest perspective on curiosity and exploration.
    applies_to: [participant]
    value_type: self_direction

  freedom:
    description: "Importance of personal freedom and independence"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is personal freedom and independence very important
      to you? Share your honest perspective on autonomy.
    applies_to: [participant]
    value_type: self_direction

  choosing_own_goals:
    description: "Importance of selecting own purposes"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, is it important to select your own purposes and
      direction in life? Share your honest perspective.
    applies_to: [participant]
    value_type: self_direction

  independent:
    description: "Value of self-reliance"
    type: numeric
    min: 0
    max: 10
    prompt_template: |
      {agent_name}, do you value self-reliance and independence?
      Share your honest perspective on making decisions on your own.
