      Do you stand firm in your self-regard? Share your honest perspective.
    applies_to: [participant]
    value_type: achievement

  # === HEDONISM ===
  pleasure:
    description: "Importance of personal enjoyment"
    type: judged_numeric
    min: 0
    max: 10
    prompt_template: |
